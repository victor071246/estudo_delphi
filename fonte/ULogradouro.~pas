procedure TfrmLogradouro.radio_group1Click(Sender: TObject);
begin
    qryLogradouro.Close;
    qryLogradouro.SQL.Clear;


    case radio_group1.itemindex of
        0:  begin
              qryLogradouro.SQL.Add('select log_codigo, log_logradouro');
              qryLogradouro.SQL.Add('FROM logradouro');
              qryLogradouro.SQL.Add('order by log_codigo');
            end;

        1:  begin
             qryLogradouro.SQL.Add('select log_codigo, log_logradouro');
              qryLogradouro.SQL.Add('FROM logradouro');
